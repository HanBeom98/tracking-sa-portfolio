rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Game rankings (existing behavior)
    match /tetris_rankings/{document=**} {
      allow read, write: if true;
    }

    match /ai_evolution_rankings/{document=**} {
      allow read, write: if true;
    }

    // News/search read access for public pages
    match /posts/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Futures estimate chart public read access
    match /futures_estimate_points/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /futures_estimate_meta/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
