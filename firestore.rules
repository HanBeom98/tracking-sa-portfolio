rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: check if user is admin
    function isAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Helper: check if resource owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Game rankings: Only allow adding new records, prevent modification of existing ones
    match /tetris_rankings/{docId} {
      allow read: if true;
      allow create: if request.resource.data.score is number;
      allow update, delete: if false;
    }

    match /ai_evolution_rankings/{docId} {
      allow read: if true;
      allow create: if request.resource.data.score is number;
      allow update, delete: if false;
    }

    // News/search: Public read, admin-only management
    match /posts/{document=**} {
      allow read: if true;
      allow delete: if isAdmin();
      allow create, update: if false; // Managed via Admin SDK / MAS
    }

    // Board posts: Public read, authenticated write, owner-only edit/delete
    match /board_posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null 
        && request.resource.data.authorUid == request.auth.uid
        && (request.resource.data.category != "notice" || isAdmin());
      allow update: if request.auth != null 
        && (
          (resource.data.authorUid == request.auth.uid && request.resource.data.authorUid == resource.data.authorUid && resource.data.category != "notice")
          || isAdmin()
        );
      allow delete: if request.auth != null 
        && (resource.data.authorUid == request.auth.uid || isAdmin());
    }

    // Users profile: Self read/write, role controlled
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) 
        && request.resource.data.role == "free"; // Default role forced
      allow update: if isOwner(userId) 
        && request.resource.data.role == resource.data.role; // Prevent self-elevation to admin
      allow delete: if isOwner(userId);
    }

    // Nickname availability index
    match /nicknames/{nickname} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && !exists(/databases/$(database)/documents/nicknames/$(nickname));
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow update: if false;
    }

    // Games: Public read for approved, authenticated create for pending, admin management
    match /games/{gameId} {
      allow read: if true;
      allow create: if isAdmin() || (request.auth != null
        && request.resource.data.status == "pending"
        && request.resource.data.authorUid == request.auth.uid);
      allow update: if isAdmin() 
        || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playCount']) 
            && request.resource.data.playCount is number);
      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
