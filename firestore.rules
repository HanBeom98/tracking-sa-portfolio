rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: check if user is admin or staff
    function isStaff() {
      return request.auth != null && (
        request.auth.token.email == "hantiger24@naver.com" || 
        request.auth.token.email == "admin@trackingsa.com" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin"
      );
    }

    // Helper: check if resource owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Game rankings
    match /tetris_rankings/{docId} {
      allow read: if true;
      allow create: if request.resource.data.score is number;
      allow update, delete: if false;
    }

    match /ai_evolution_rankings/{docId} {
      allow read: if true;
      allow create: if request.resource.data.score is number;
      allow update, delete: if false;
    }

    // News/search
    match /posts/{document=**} {
      allow read: if true;
      allow delete: if isStaff();
      allow create, update: if false;
    }

    // Board posts
    match /board_posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null 
        && request.resource.data.authorUid == request.auth.uid
        && (request.resource.data.category != "notice" || isStaff());
      allow update: if request.auth != null 
        && (
          (resource.data.authorUid == request.auth.uid && request.resource.data.authorUid == resource.data.authorUid && resource.data.category != "notice")
          || isStaff()
        );
      allow delete: if request.auth != null 
        && (resource.data.authorUid == request.auth.uid || isStaff());
    }

    // Users profile
    match /users/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow create: if isOwner(userId) && request.resource.data.role == "free";
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role;
      allow delete: if isOwner(userId);
    }

    // Nickname index
    match /nicknames/{nickname} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Games
    match /games/{gameId} {
      allow read: if true;
      allow create: if isStaff() || (request.auth != null && request.resource.data.status == "pending");
      allow update: if isStaff() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playCount']));
      allow delete: if isStaff();
    }

    // Sudden Attack Crew Management (Updated)
    match /sa_crew_members/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /sa_crew_applications/{docId} {
      allow create: if true;
      allow read, update, delete: if isStaff();
    }

    match /sa_crew_history/{docId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
