rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: Dedicated admin list for crew management to avoid complex rules
    function isTeamAdmin() {
      return request.auth != null && request.auth.token.email in [
        'hantiger24@naver.com',
        'admin@trackingsa.com',
        'bjs5739@naver.com',
        'jungsion98@naver.com'
      ];
    }

    // Helper: check if resource owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Game rankings
    match /tetris_rankings/{docId} {
      allow read: if true;
      allow create: if request.resource.data.score is number;
      allow update, delete: if false;
    }

    match /ai_evolution_rankings/{docId} {
      allow read: if true;
      allow create: if request.resource.data.score is number;
      allow update, delete: if false;
    }

    // News/search
    match /posts/{document=**} {
      allow read: if true;
      allow delete: if isTeamAdmin();
      allow create, update: if false;
    }

    // Board posts
    match /board_posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null 
        && request.resource.data.authorUid == request.auth.uid
        && (request.resource.data.category != "notice" || isTeamAdmin());
      allow update: if request.auth != null 
        && (
          (resource.data.authorUid == request.auth.uid && request.resource.data.authorUid == resource.data.authorUid && resource.data.category != "notice")
          || isTeamAdmin()
        );
      allow delete: if request.auth != null 
        && (resource.data.authorUid == request.auth.uid || isTeamAdmin());
    }

    // Users profile
    match /users/{userId} {
      allow read: if isOwner(userId) || isTeamAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == "free";
      allow update: if isOwner(userId) && request.resource.data.role == resource.data.role;
      allow delete: if isOwner(userId);
    }

    // Nickname index
    match /nicknames/{nickname} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    // Games
    match /games/{gameId} {
      allow read: if true;
      allow create: if isTeamAdmin() || (request.auth != null && request.resource.data.status == "pending");
      allow update: if isTeamAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['playCount']));
      allow delete: if isTeamAdmin();
    }

    // Sudden Attack Crew Management (Using dedicated Team Admin rule)
    match /sa_crew_members/{docId} {
      allow read: if true;
      allow write: if isTeamAdmin();
    }

    match /sa_crew_applications/{docId} {
      allow create: if true;
      allow read, update, delete: if isTeamAdmin();
    }

    match /sa_crew_history/{docId} {
      allow read: if true;
      allow write: if isTeamAdmin();
    }

    match /sa_crew_settings/{docId} {
      allow read: if true;
      allow write: if isTeamAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
