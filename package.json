{
  "name": "tracking-sa",
  "version": "1.0.0",
  "description": "A simple HTML/JS/CSS starter template",
  "type": "module",
  "main": "common.js",
  "scripts": {
    "build": "[ -x venv/bin/python ] && venv/bin/python main.py --build-only || python3 main.py --build-only",
    "build:full": "[ -x venv/bin/python ] && venv/bin/python main.py || python3 main.py",
    "sync:public": "bash scripts/sync_public_assets.sh",
    "check:public-sync": "bash scripts/sync_public_assets.sh --check",
    "test:smoke:release": "bash scripts/smoke_auth_release.sh",
    "test:rules": "node --test tests/unit/firestore-rules-guards.test.js",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:e2e": "playwright test",
    "test:e2e:auth": "playwright test tests/e2e/auth-smoke.spec.js",
    "test": "npm run test:e2e:auth"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0"
  }
}
